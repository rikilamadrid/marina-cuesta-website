# Sanity — read by src/sanity/env.ts
# Get these from https://www.sanity.io/manage (or the CLI output after creating a project).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Write token — only needed to run the seed script (scripts/seed.mjs), never at runtime.
# Create one at sanity.io/manage → API → Tokens with Editor access. Keep it out of git.
SANITY_API_WRITE_TOKEN=
